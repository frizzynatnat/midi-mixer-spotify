{
  "$schema": "./node_modules/midi-mixer-plugin/plugin.schema.json",
  "id": "ca.jaggernaut.midi-mixer.spotify",
  "name": "Spotify",
  "type": "node",
  "version": "1.1.5",
  "author": "Jaggernaut",
  "main": "lib/index.js",
  "icon": "circle.ico",
  "settings": {
    "SpotifyPremiumWarning": {
      "label": "SPOTIFY PREMIUM REQUIRED TO USE THE SPOTIFY API",
      "type": "status"
    },
    "SpotifyClientID": {
      "label": "Client ID",
      "required": true,
      "type": "text",
      "fallback": "None"
    },
    "SpotifyClientSecret": {
      "label": "Client Secret",
      "required": true,
      "type": "password",
      "fallback": "None"
    },
    "SpotifyAccessToken": {
      "label": "Access Token",
      "type": "password",
      "fallback": "None"
    },
    "SpotifyRefreshToken": {
      "label": "Refresh Token",
      "type": "password",
      "fallback": "None"
    },
    "SpotifyNotifications": {
      "label": "Enable Track Saved/Shuffle/Repeat notifications",
      "type": "toggle",
      "fallback": false
    },
    "SpotifyExpressStatus": {
      "label": "Express server status",
      "type": "status",
      "fallback": "Not Running"
    },
    "SpotifyRunLogin": {
      "label": "Run Login Server",
      "type": "button"
    }
  }
}